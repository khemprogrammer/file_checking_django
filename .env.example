# Database (PostgreSQL) - Update these with your PostgreSQL credentials
DB_NAME=secure_upload
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# For Render deployment, use this format:
# DATABASE_URL=postgres://user:password@host:port/dbname

# Django Secret Key
SECRET_KEY=your-secret-key-here

# Debug (set to False in production)
DEBUG=True